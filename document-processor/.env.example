LOG_LEVEL=INFO
# ENVIRONMENT=production
# PORT=8080
# Concurrent SQS poller workers (1-32)
# NUM_THREADS=4
# Target chunk size in tokens (o200k_base / gpt-4o)
# CHUNK_SIZE_TOKENS=300
# SQS message visibility timeout in seconds (heartbeat extends it while processing)
# SQS_VISIBILITY_TIMEOUT=300
# PDFs with more pages than this are split into parts processed in parallel (0 disables)
# PDF_PAGE_BATCH_SIZE=10
# Hard cap on a single parse; on timeout the document is failed instead of hanging
# PARSE_TIMEOUT_SECONDS=1800
# Per-operation timeout for S3 calls (download/upload/head)
# S3_TIMEOUT_SECONDS=120

############################# S3 Configuration (LocalStack on localhost)
S3_ENDPOINT=http://localhost:4566
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=localstack
S3_SECRET_ACCESS_KEY=localstack
S3_FILES_BUCKET_NAME=katechatdevfiles

############################# SQS Configuration (LocalStack on localhost)
SQS_ENDPOINT=http://localhost:4566
SQS_REGION=eu-central-1
SQS_ACCESS_KEY_ID=localstack
SQS_SECRET_ACCESS_KEY=localstack
SQS_DOCUMENTS_QUEUE=http://sqs.eu-central-1.localhost.localstack.cloud:4566/000000000000/documents-queue
SQS_INDEX_DOCUMENTS_QUEUE=http://sqs.eu-central-1.localhost.localstack.cloud:4566/000000000000/documents-index-queue

REDIS_URL=redis://localhost:6379

############################# PDF/image ML pipeline
# ONNX execution provider: cpu (default when unset), cuda (fail loudly if the GPU
# can't initialize), auto (use the GPU when present, fall back to CPU). The CUDA
# provider is compiled in by the cargo build; a native run additionally needs the
# CUDA 12 runtime + cuDNN 9 libraries on the machine (the Docker image sets auto).
# DOCLING_RS_EP=auto

# pdfium + models resolve relative to the working directory (.pdfium/, models/ from
# scripts/install/download_dependencies.sh); explicit overrides:
# PDFIUM_DYNAMIC_LIB_PATH=/opt/pdfium/lib
# DOCLING_LAYOUT_ONNX=models/layout_heron.onnx
# DOCLING_OCR_REC_ONNX=models/ocr_rec.onnx
# DOCLING_OCR_DICT=models/ppocr_keys_v1.txt
